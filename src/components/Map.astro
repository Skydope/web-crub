---
const {
  title = "Dirección:",
  src,
  aspect = "16/9", // 16/9, 4/3, square
  fullHeight = false,
  allowFullscreen = true,
} = Astro.props;

const aspectClass = {
  "16/9": "aspect-video",
  "4/3": "aspect-[4/3]",
  "square": "aspect-square",
}[aspect] || "aspect-video";
---

<section class="mb-10 text-center">
  {title && (
    <h3 class="text-2xl text-gray-800 font-bold mb-4">{title}</h3>
  )}

  <div class={`relative w-full ${fullHeight ? "h-screen" : aspectClass}`}>
    <iframe
      src={src}
      class="absolute inset-0 w-full h-full rounded-lg shadow-md"
      style="border:0"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>
</section>
