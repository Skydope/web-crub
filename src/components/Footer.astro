---

---

<footer class="bg-gradient-to-br from-[#003366] to-[#025fbd] text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Logos de instituciones -->
      <div>
        <!-- Logo CRUB -->
        <a href="/">
        <img src="/svg/logo-nuevo.svg" alt="CRUB" class="md:h-20 lg:h-16 w-auto">
        </a>

        <!-- Logo Educación -->
        <a href="/" target="_blank" rel="noopener noreferrer">
        <img src="/svg/logo-edu.svg" alt="Educación" class="md:h-20 lg:h-16 w-auto">
        </a>

        <!-- Logo Municipalidad -->
        <a href="https://www.bolivar.gob.ar/" target="_blank" rel="noopener noreferrer">
        <img src="/svg/logo-muni.svg" alt="Municipalidad de Bolívar" class="md:h-20 lg:h-16 w-auto">
        </a>
      </div>

      <div class="flex flex-col items-center text-center">
        <h4 class="font-semibold mb-3">Contacto</h4>
        <ul class="space-y-2 text-blue-200 text-sm">
          <li class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-map-pin h-4 w-4 flex-shrink-0"
              aria-hidden="true"
              ><path
                d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
              ></path><circle cx="12" cy="10" r="3"></circle></svg
            ><span>Bolívar, Buenos Aires</span>
          </li>
          <li class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-phone h-4 w-4 flex-shrink-0"
              aria-hidden="true"
              ><path
                d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"
              ></path></svg
            ><a
              href="tel:+540231415417550"
              class="hover:text-white transition-colors">+54 (02314) 15417550</a>
          </li>
          <li class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-mail h-4 w-4 flex-shrink-0"
              aria-hidden="true"
              ><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect
                x="2"
                y="4"
                width="20"
                height="16"
                rx="2"></rect></svg
            ><a
              href="mailto:crub@bolivar.gob.ar"
              class="hover:text-white transition-colors">crub@bolivar.gob.ar</a>
          </li>
        </ul>
      </div>

      <div class="flex flex-col items-center text-center">
        <h4 class="font-semibold mb-3">Enlaces</h4>
        <ul class="space-y-2 text-blue-200 text-sm">
          <li>
            <a href="/institucional/historia" class="hover:text-white transition-colors"
              >Institución</a>
          </li>
          <li>
            <a href="/oferta" class="hover:text-white transition-colors"
              >Oferta Académica</a>
          </li>
          <li>
            <a href="/extension" class="hover:text-white transition-colors"
              >Extensión</a>
          </li>
          <li>
            <a href="/contacto" class="hover:text-white transition-colors"
              >Contacto</a>
          </li>
          <li>
            <p>Horario de atención
            Lunes a Viernes: 8:00 - 21:00
            Sábados: 9:00 - 13:00</p>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white mt-6 pt-6 text-center text-blue-200 text-sm">
      <p>
        &copy; 2026 Centro Regional Universitario Bolívar. Todos los derechos
        reservados.
      </p>
    </div>
  </div>
</footer>
