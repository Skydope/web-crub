---
import { getCollection } from "astro:content";
import { formatearFecha, ordenarPorFecha } from "../utils/date";

const noticias = await getCollection("noticias");
const noticiasOrdenadas = ordenarPorFecha(noticias).slice(0, 6);
---

<section id="noticias" class="py-16 bg-white scroll-mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Últimas Noticias</h2>
      <p class="text-xl text-gray-600">Mantente informado sobre las novedades del CRUB</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
      {noticiasOrdenadas.map((noticia) => (
        
        <article
          class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300"
        >
          <div class="relative">
            <a
                href={`/noticias/${noticia.slug}/`}>
            <img
              src={noticia.data.imagen}
              alt={noticia.data.titulo}
              class="w-full h-48 object-cover"
              loading="lazy"
            />
            </a>
            <div class="absolute top-4 left-4">
              <span
                class="bg-blue-600 text-white px-2 py-1 rounded text-sm font-medium"
              >
                {noticia.data.categoria}
              </span>
            </div>
          </div>

          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-2 line-clamp-2">
              {noticia.data.titulo}
            </h3>
            <p class="text-gray-600 mb-4 line-clamp-3">
              {noticia.data.descripcion}
            </p>

            <div class="flex justify-between items-center">
              <time class="text-sm text-gray-500">
                {formatearFecha(noticia.data.fecha)}
              </time>

              <a
                href={`/noticias/${noticia.slug}/`}
                class="text-blue-600 hover:text-blue-800 font-medium flex items-center gap-1 transition-colors"
              >
                Leer más
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4"
                >
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center">
      <a href="/noticias">
      <button
        class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors"
      >
        Cargar más noticias
      </button>
      </a>
    </div>
  </div>
</section>
