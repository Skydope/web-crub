---
import Map from './Map.astro';

const {
  title = "Nuestra Ubicación",
  subtitle = "Visitanos en nuestro campus universitario",
  mapSrc,
} = Astro.props;
---

<section class="relative bg-gradient-to-tr from-[#003366] to-[#025fbd] text-white py-20 overflow-hidden">
  <!-- Patrón decorativo de fondo -->
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute inset-0"
      style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.4\'%3E%3Ccircle cx=\'7\' cy=\'7\' r=\'7\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"
    ></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Encabezado de la sección -->
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 text-white">
        {title}
      </h2>
      <p class="text-xl md:text-2xl opacity-90 max-w-2xl mx-auto">
        {subtitle}
      </p>
      <div class="w-24 h-1 bg-white mx-auto mt-6"></div>
    </div>

    <!-- Grid de contenido -->
    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <!-- Información de contacto -->
      <div class="space-y-8">
        <!-- Dirección -->
        <div class="bg-white/10 backdrop-blur-sm rounded-lg p-6 hover:bg-white/15 transition-all duration-300">
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-white flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <div>
              <h3 class="text-xl font-semibold mb-2">Dirección</h3>
              <p class="text-white/90">CRUB Centro Regional Universitario Bolívar</p>
              <p class="text-white/90">Bolívar, Buenos Aires, Argentina</p>
              <p class="text-white/90">Av. Cacique Gral. Ignacio Coliqueo</p>
            </div>
          </div>
        </div>

        <!-- Horarios -->
        <div class="bg-white/10 backdrop-blur-sm rounded-lg p-6 hover:bg-white/15 transition-all duration-300">
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-white flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <h3 class="text-xl font-semibold mb-2">Horarios de Atención</h3>
              <p class="text-white/90">Lunes a Viernes: 8:00 - 20:00</p>
              <p class="text-white/90">Sábados: 9:00 - 13:00</p>
            </div>
          </div>
        </div>

        <!-- Teléfono -->
        <div class="bg-white/10 backdrop-blur-sm rounded-lg p-6 hover:bg-white/15 transition-all duration-300">
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-white flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <div>
              <h3 class="text-xl font-semibold mb-2">Contacto</h3>
              <p class="text-white/90">Tel: +54 (2314) 42-4000</p>
              <p class="text-white/90">Email: info@crub.edu.ar</p>
            </div>
          </div>
        </div>

        <!-- Cómo llegar -->
         <!-- 
        <div class="bg-white/20 border-2 border-white/30 rounded-lg p-6">
          <h3 class="text-xl font-semibold mb-3 text-white">¿Cómo llegar?</h3>
          <ul class="space-y-2 text-white/90">
            <li class="flex items-start gap-2">
              <span class="text-white mt-1">•</span>
              <span>En auto: Acceso directo desde Ruta Nacional 226</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-white mt-1">•</span>
              <span>Transporte público: Líneas 1, 5 y 7 con parada en campus</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-white mt-1">•</span>
              <span>Estacionamiento gratuito disponible para estudiantes</span>
            </li>
          </ul>
        </div> -->
      </div>

      <!-- Mapa -->
      <div class="bg-white rounded-lg shadow-2xl p-2">
                  <Map 
            title="¿Cómo llegar?"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3218.9238844189904!2d-61.11923812359784!3d-36.217044972419075!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bfe3342b9b60b5%3A0x722a9bf1e549924a!2sCRUB%20Centro%20Regional%20Universitario%20Bol%C3%ADvar!5e0!3m2!1ses!2sar!4v1765266866062!5m2!1ses!2sar"
            width="100%"
            height="400"
          />
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
