---
import { getCollection } from "astro:content";

// Obtener noticias
const noticias = await getCollection("noticias");

// Ordenar por fecha (dd-mm-yyyy → Date → ordenar)
const noticiasOrdenadas = noticias.sort((a, b) => {
  const [diaA, mesA, anioA] = a.data.fecha.split("-").map(Number);
  const [diaB, mesB, anioB] = b.data.fecha.split("-").map(Number);

  const fechaA = new Date(anioA, mesA - 1, diaA);
  const fechaB = new Date(anioB, mesB - 1, diaB);

  return fechaB - fechaA; // más reciente primero
});

// Función para formatear fecha localmente
function formatearFecha(fechaStr) {
  const [dia, mes, anio] = fechaStr.split("-").map(Number);
  const fecha = new Date(anio, mes - 1, dia);

  return fecha.toLocaleDateString("es-AR", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

const NOTICIAS_POR_PAGINA = 6;
const totalNoticias = noticiasOrdenadas.length;
const totalPaginas = Math.ceil(totalNoticias / NOTICIAS_POR_PAGINA);
---

<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Todas las Noticias</h2>
      <p class="text-xl text-gray-600">
        Mantente informado sobre las novedades del CRUB
      </p>
    </div>

    <!-- Grid de noticias -->
    <div id="noticias-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
      {noticiasOrdenadas.map((noticia, index) => (
        <article
          class="noticia-item bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300"
          data-page={Math.floor(index / NOTICIAS_POR_PAGINA) + 1}
          style={index >= NOTICIAS_POR_PAGINA ? "display: none;" : ""}
        >
          <div class="relative">
            <a href={`/noticias/${noticia.slug}/`}>
              <img
                src={noticia.data.imagen}
                alt={noticia.data.titulo}
                class="w-full h-48 object-cover"
                loading="lazy"
              />
            </a>
            <div class="absolute top-4 left-4">
              <span class="bg-blue-600 text-white px-2 py-1 rounded text-sm font-medium">
                {noticia.data.categoria}
              </span>
            </div>
          </div>

          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-2 line-clamp-2">
              {noticia.data.titulo}
            </h3>
            <p class="text-gray-600 mb-4 line-clamp-3">
              {noticia.data.descripcion}
            </p>

            <div class="flex justify-between items-center">
              <time class="text-sm text-gray-500">
                {formatearFecha(noticia.data.fecha)}
              </time>

              <a
                href={`/noticias/${noticia.slug}/`}
                class="text-blue-600 hover:text-blue-800 font-medium flex items-center gap-1 transition-colors"
              >
                Leer más
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4"
                >
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Navegación de paginación -->
    <div class="flex justify-center items-center gap-2 flex-wrap">
      <!-- Botón Anterior -->
      <button
        id="btn-anterior"
        class="px-4 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        disabled
      >
        ← Anterior
      </button>

      <!-- Números de página -->
      <div id="numeros-pagina" class="flex gap-2">
        {Array.from({ length: totalPaginas }, (_, i) => i + 1).map((num) => (
          <button
            class={`pagina-btn px-4 py-2 rounded-lg transition-colors ${
              num === 1
                ? "bg-blue-600 text-white"
                : "border border-gray-300 text-gray-700 hover:bg-gray-50"
            }`}
            data-page={num}
          >
            {num}
          </button>
        ))}
      </div>

      <!-- Botón Siguiente -->
      <button
        id="btn-siguiente"
        class="px-4 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Siguiente →
      </button>
    </div>

    <!-- Información de página actual -->
    <div class="text-center mt-4 text-gray-600">
      Página <span id="pagina-actual">1</span> de <span id="total-paginas">{totalPaginas}</span>
    </div>
  </div>
</section>

<script>
  let paginaActual = 1;
  const totalPaginas = parseInt(document.getElementById("total-paginas")?.textContent || "1");

  function mostrarPagina(numeroPagina: number) {
    // Ocultar todas las noticias
    const noticias = document.querySelectorAll(".noticia-item");
    noticias.forEach((noticia) => {
      (noticia as HTMLElement).style.display = "none";
    });

    // Mostrar solo las noticias de la página actual
    const noticiasPagina = document.querySelectorAll(
      `.noticia-item[data-page="${numeroPagina}"]`
    );
    noticiasPagina.forEach((noticia) => {
      (noticia as HTMLElement).style.display = "block";
    });

    // Actualizar estilos de botones
    const botones = document.querySelectorAll(".pagina-btn");
    botones.forEach((btn) => {
      const boton = btn as HTMLButtonElement;
      if (parseInt(boton.dataset.page || "0") === numeroPagina) {
        boton.classList.remove("border", "border-gray-300", "text-gray-700", "hover:bg-gray-50");
        boton.classList.add("bg-blue-600", "text-white");
      } else {
        boton.classList.remove("bg-blue-600", "text-white");
        boton.classList.add("border", "border-gray-300", "text-gray-700", "hover:bg-gray-50");
      }
    });

    // Actualizar botones anterior/siguiente
    const btnAnterior = document.getElementById("btn-anterior") as HTMLButtonElement;
    const btnSiguiente = document.getElementById("btn-siguiente") as HTMLButtonElement;

    if (btnAnterior) {
      btnAnterior.disabled = numeroPagina === 1;
    }

    if (btnSiguiente) {
      btnSiguiente.disabled = numeroPagina === totalPaginas;
    }

    // Actualizar texto de página actual
    const paginaActualElement = document.getElementById("pagina-actual");
    if (paginaActualElement) {
      paginaActualElement.textContent = numeroPagina.toString();
    }

    // Scroll suave al inicio de la sección
    document.getElementById("noticias-grid")?.scrollIntoView({
      behavior: "smooth",
      block: "start",
    });

    paginaActual = numeroPagina;
  }

  // Event listeners para botones de número de página
  document.querySelectorAll(".pagina-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const numeroPagina = parseInt((btn as HTMLButtonElement).dataset.page || "1");
      mostrarPagina(numeroPagina);
    });
  });

  // Event listener para botón anterior
  document.getElementById("btn-anterior")?.addEventListener("click", () => {
    if (paginaActual > 1) {
      mostrarPagina(paginaActual - 1);
    }
  });

  // Event listener para botón siguiente
  document.getElementById("btn-siguiente")?.addEventListener("click", () => {
    if (paginaActual < totalPaginas) {
      mostrarPagina(paginaActual + 1);
    }
  });
</script>