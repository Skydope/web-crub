---
import Carousel from './Carousel.astro';
import { getCollection } from 'astro:content';

const propuestas = await getCollection('propuestas');

const items = propuestas.map(p => ({
  img: p.data.img,
  titulo: p.data.titulo,
  universidad: p.data.universidad,
  duracion: p.data.duracion,
  modalidad: p.data.modalidad,
  nivel: p.data.nivel,
  url: p.data.url,
}));
---

<section class="py-12 bg-gray-100">
  <div class="max-w-6xl mx-auto px-4 text-center">
    <h2 class="text-4xl font-bold text-gray-900 mb-4">Carreras Destacadas</h2>
    <Carousel items={items} autoplay={true} interval={4000} />
  </div>
</section>
