---
import Banner from '../components/Banner.astro';
import HeroSectionCursadas from '../components/HeroSectionCursadas.astro';
import Noticias from '../components/Noticias.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import Ubicacion from '../components/Ubicacion.astro'; 
---
<BaseLayout title="Inicio" description="Página principal en la que se muestra la información más relevante.">
    
<Banner
  title="Centro Regional Universitario Bolívar"
  description="Excelencia académica en el corazón de Buenos Aires."
  showButton={true}
  buttonText="Conocer más"
  buttonLink="/institucional/historia"
/>

<HeroSectionCursadas/>
    
<Noticias />

<Ubicacion />

</BaseLayout>
