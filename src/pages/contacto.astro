---
import BaseLayout from '../layouts/BaseLayout.astro'
import Banner from '../components/Banner.astro'
import Map from '../components/Map.astro'
import Faq from '../components/Faq.astro'

const faqsContacto = [
  {
    question: "¿Cómo puedo inscribirme en una carrera?",
    answer: "Puedes inscribirte completando el formulario en línea en nuestra sección de Inscripciones o acercándote personalmente a nuestras oficinas durante el horario de atención."
  },
  {
    question: "¿Qué carreras ofrece el CRUB?",
    answer: "Ofrecemos diversas carreras de grado y posgrado. Visita nuestra sección de Oferta Académica para conocer el listado completo de carreras disponibles."
  },
  {
    question: "¿Tienen becas disponibles?",
    answer: "Sí, contamos con diversos programas de becas para estudiantes. Comunícate con nosotros para conocer los requisitos y convocatorias vigentes."
  },
  {
    question: "¿Cuál es el horario de atención?",
    answer: "Nuestro horario de atención es de lunes a viernes de 8:00 a 18:00 horas, y los sábados de 9:00 a 13:00 horas."
  }
];
---

<BaseLayout 
  title="Contacto" 
  description="Ponte en contacto con el Centro Regional Universitario Bolívar"
>
  <Banner
    title="Contacto"
    description="Estamos aquí para ayudarte. Completa el formulario o utiliza nuestros medios de contacto."
    gradient="from-blue-900 to-blue-700"
  />

  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        
        <!-- Formulario de contacto -->
        <div class="bg-white rounded-lg shadow-lg p-8">
          <h2 class="text-3xl font-bold text-blue-900 mb-6">Envíanos un mensaje</h2>
          
          <form action="mailto:crub@bolivar.gob.ar" method="POST" enctype="text/plain" class="space-y-6">
            <div>
              <label for="nombre" class="block text-sm font-semibold text-blue-900 mb-2">
                Nombre completo *
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all duration-200"
                placeholder="Tu nombre"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-semibold text-blue-900 mb-2">
                Email *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all duration-200"
                placeholder="tucorreo@ejemplo.com"
              />
            </div>

            <div>
              <label for="telefono" class="block text-sm font-semibold text-blue-900 mb-2">
                Teléfono
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all duration-200"
                placeholder="(02314) 424-000"
              />
            </div>

            <div>
              <label for="asunto" class="block text-sm font-semibold text-blue-900 mb-2">
                Asunto *
              </label>
              <select
                id="asunto"
                name="asunto"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all duration-200"
              >
                <option value="">Selecciona un asunto</option>
                <option value="consulta-general">Consulta general</option>
                <option value="oferta-academica">Oferta académica</option>
                <option value="inscripciones">Inscripciones</option>
                <option value="casas-estudiantiles">Casas estudiantiles</option>
                <option value="extension">Extensión</option>
                <option value="proyectos">Proyectos</option>
                <option value="otro">Otro</option>
              </select>
            </div>

            <div>
              <label for="mensaje" class="block text-sm font-semibold text-blue-900 mb-2">
                Mensaje *
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="6"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all duration-200 resize-none"
                placeholder="Escribe tu consulta aquí..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-blue-900 text-white py-3 px-6 rounded-lg font-semibold hover:bg-blue-800 transition-all duration-300 transform hover:scale-105 shadow-lg"
            >
              Enviar mensaje
            </button>
          </form>
        </div>

        <!-- Información de contacto -->
        <div class="space-y-8">
          <div class="bg-white rounded-lg shadow-lg p-8">
            <h2 class="text-3xl font-bold text-blue-900 mb-6">Información de contacto</h2>
            
            <div class="space-y-6">
              <!-- Dirección -->
              <div class="flex items-start gap-4">
                <div class="bg-blue-100 p-3 rounded-lg flex-shrink-0">
                  <svg 
                    xmlns="http://www.w3.org/2000/svg" 
                    class="h-6 w-6 text-blue-900" 
                    fill="none" 
                    viewBox="0 0 24 24" 
                    stroke="currentColor"
                  >
                    <path 
                      stroke-linecap="round" 
                      stroke-linejoin="round" 
                      stroke-width="2" 
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" 
                    />
                    <path 
                      stroke-linecap="round" 
                      stroke-linejoin="round" 
                      stroke-width="2" 
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" 
                    />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-blue-900 mb-1">Dirección</h3>
                  <p class="text-gray-600">
                    Av. Cacique Coliqueo 940<br />
                    Bolívar, Buenos Aires<br />
                    Argentina
                  </p>
                </div>
              </div>

              <!-- Teléfono -->
              <div class="flex items-start gap-4">
                <div class="bg-blue-100 p-3 rounded-lg flex-shrink-0">
                  <svg 
                    xmlns="http://www.w3.org/2000/svg" 
                    class="h-6 w-6 text-blue-900" 
                    fill="none" 
                    viewBox="0 0 24 24" 
                    stroke="currentColor"
                  >
                    <path 
                      stroke-linecap="round" 
                      stroke-linejoin="round" 
                      stroke-width="2" 
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" 
                    />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-blue-900 mb-1">Teléfono</h3>
                  <a 
                    href="tel:+542314424000" 
                    class="text-gray-600 hover:text-blue-900 transition-colors"
                  >
                     (02314) 15417550 
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="bg-blue-100 p-3 rounded-lg flex-shrink-0">
                  <svg 
                    xmlns="http://www.w3.org/2000/svg" 
                    class="h-6 w-6 text-blue-900" 
                    fill="none" 
                    viewBox="0 0 24 24" 
                    stroke="currentColor"
                  >
                    <path 
                      stroke-linecap="round" 
                      stroke-linejoin="round" 
                      stroke-width="2" 
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" 
                    />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-blue-900 mb-1">Email</h3>
                  <a 
                    href="mailto:crub@bolivar.gob.ar" 
                    class="text-gray-600 hover:text-blue-900 transition-colors"
                  >
                    crub@bolivar.gob.ar
                  </a>
                </div>
              </div>

              <!-- Horarios -->
              <div class="flex items-start gap-4">
                <div class="bg-blue-100 p-3 rounded-lg flex-shrink-0">
                  <svg 
                    xmlns="http://www.w3.org/2000/svg" 
                    class="h-6 w-6 text-blue-900" 
                    fill="none" 
                    viewBox="0 0 24 24" 
                    stroke="currentColor"
                  >
                    <path 
                      stroke-linecap="round" 
                      stroke-linejoin="round" 
                      stroke-width="2" 
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" 
                    />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-blue-900 mb-1">Horario de atención</h3>
                  <p class="text-gray-600">
                    Lunes a Viernes: 8:00 - 21:00<br />
                    Sábados: 9:00 - 13:00
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Mapa -->
          <Map 
            title="Nuestra ubicación"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3218.9238844189904!2d-61.11923812359784!3d-36.217044972419075!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bfe3342b9b60b5%3A0x722a9bf1e549924a!2sCRUB%20Centro%20Regional%20Universitario%20Bol%C3%ADvar!5e0!3m2!1ses!2sar!4v1765266866062!5m2!1ses!2sar"
            width="100%"
            height="400"
          />

        </div>

      </div>
    </div>
  </section>

  <Faq
    faqs={faqsContacto}
  />
</BaseLayout>
