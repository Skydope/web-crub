---
import BaseLayout from '../layouts/BaseLayout.astro'
import Banner from '../components/Banner.astro'
---

<BaseLayout
    title="UBA XXI"
    description="Información sobre el programa UBA XXI: materias del Ciclo Básico Común en modalidad virtual disponibles en la subsede de Bolívar."
>
  <Banner
    title="UBA XXI"
    description=""
    showButton={false}
    heightClass="py-20"
  />

  <section class="max-w-7xl mx-auto py-12 px-4">
    <div class="grid lg:grid-cols-3 gap-8">

      <!-- Columna izquierda - Panel de información -->
      <aside class="lg:col-span-1">
        <!-- Imagen destacada -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden mb-6">
          <img
            src="/img/logos-universidades/uba.jpg"
            alt="UBA XXI"
            class="w-full h-56 object-cover"
          />
        </div>

        <!-- Panel de datos clave -->
        <div class="bg-white rounded-xl shadow-lg p-6 space-y-6">
          <h3 class="text-xl font-bold text-gray-900 mb-4 border-b pb-3">
            Información General
          </h3>

          <!-- Institución -->
          <div class="space-y-2">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              Institución
            </div>
            <p class="text-gray-900 font-semibold pl-7">Universidad de Buenos Aires (UBA)</p>
          </div>

          <!-- Modalidad -->
          <div class="space-y-2">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Modalidad
            </div>
            <p class="text-gray-900 font-semibold pl-7">Virtual (cursada) + Presencial (exámenes)</p>
          </div>

          <!-- Ciclo -->
          <div class="space-y-2">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              Ciclo
            </div>
            <p class="text-gray-900 font-semibold pl-7">Ciclo Básico Común (CBC)</p>
          </div>

          <!-- Financiamiento -->
          <div class="space-y-2">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Financiamiento
            </div>
            <p class="text-gray-900 font-semibold pl-7">Gratuito</p>
          </div>

          <!-- Botón inscripción -->
          <div class="space-y-2 pt-4 border-t">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Inscripción
            </div>
            <a
              href="/inscripciones"
              class="inline-flex items-center gap-2 bg-blue-900 text-white px-3 py-2 rounded-lg font-semibold hover:bg-blue-600 transition-all duration-300 transform hover:scale-105 shadow-lg"
            >
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
              Inscribirme
            </a>
          </div>

          <!-- Categoría -->
          <div class="space-y-2 pt-4 border-t">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
              </svg>
              Categoría
            </div>
            <span class="inline-block ml-7 px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm font-semibold">
              Preuniversitario
            </span>
          </div>
        </div>
      </aside>

      <!-- Columna derecha - Contenido principal -->
      <main class="lg:col-span-2 space-y-6">

        <!-- Descripción -->
        <div class="bg-white rounded-xl shadow-lg p-8">
          <h1 class="text-3xl font-bold mb-6 text-gray-900 border-b pb-4">
            UBA XXI
          </h1>
          <p class="text-gray-700 text-lg leading-relaxed mb-4">
            UBA XXI es el Programa de la UBA que dicta materias del Ciclo Básico Común en modalidad virtual.
            La cursada es a distancia, a través del Campus Virtual, y los exámenes son presenciales.
          </p>
          <p class="text-gray-700 text-lg leading-relaxed">
            En la subsede de Bolívar los estudiantes pueden rendir los exámenes parciales y finales, y asistir
            a tutorías. Esto permite iniciar los estudios en la Universidad sin necesidad de trasladarse.
          </p>
        </div>

        <!-- Quiénes pueden inscribirse -->
        <div class="bg-white rounded-xl shadow-lg p-8">
          <h2 class="text-2xl font-bold mb-6 text-gray-900 border-b pb-4">
            ¿Quiénes pueden inscribirse?
          </h2>
          <ul class="space-y-4">
            <li class="flex items-start gap-4 p-4 bg-gray-50 rounded-lg">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-900 flex items-center justify-center text-white font-bold text-sm">1</span>
              <p class="text-gray-700 text-lg leading-relaxed pt-0.5">Ingresantes a la Universidad.</p>
            </li>
            <li class="flex items-start gap-4 p-4 bg-gray-50 rounded-lg">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-900 flex items-center justify-center text-white font-bold text-sm">2</span>
              <p class="text-gray-700 text-lg leading-relaxed pt-0.5">Estudiantes de los 2 últimos años de la escuela secundaria (4° y 5°, o 5° y 6°).</p>
            </li>
            <li class="flex items-start gap-4 p-4 bg-gray-50 rounded-lg">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-900 flex items-center justify-center text-white font-bold text-sm">3</span>
              <p class="text-gray-700 text-lg leading-relaxed pt-0.5">Estudiantes que estén cursando el último ciclo de las modalidades de estudios secundarios para adultos y programas especiales.</p>
            </li>
          </ul>
        </div>

        <!-- Materias disponibles en Bolívar -->
        <div class="bg-white rounded-xl shadow-lg p-8">
          <h2 class="text-2xl font-bold mb-6 text-gray-900 border-b pb-4">
            ¿Qué materias se pueden cursar en Bolívar?
          </h2>
          <div class="grid sm:grid-cols-2 gap-4">

            <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-colors duration-200">
              <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-gray-900 text-sm">Introducción al Conocimiento de la Sociedad y el Estado</p>
                <span class="text-xs text-blue-600 font-medium">ICSE — Cód. 024</span>
              </div>
            </div>

            <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-colors duration-200">
              <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-gray-900 text-sm">Matemática</p>
                <span class="text-xs text-blue-600 font-medium">Cód. 051</span>
              </div>
            </div>

            <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-colors duration-200">
              <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-gray-900 text-sm">Química</p>
                <span class="text-xs text-blue-600 font-medium">Cód. 005</span>
              </div>
            </div>

            <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-colors duration-200">
              <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-gray-900 text-sm">Introducción al Pensamiento Científico</p>
                <span class="text-xs text-blue-600 font-medium">IPC — Cód. 040</span>
              </div>
            </div>

            <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-colors duration-200">
              <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-gray-900 text-sm">Sociología</p>
                <span class="text-xs text-blue-600 font-medium">Cód. 014</span>
              </div>
            </div>

            <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-colors duration-200">
              <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-gray-900 text-sm">Biología</p>
                <span class="text-xs text-blue-600 font-medium">Cód. 008</span>
              </div>
            </div>

          </div>
        </div>

      </main>
    </div>
  </section>
</BaseLayout>
