---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Banner from '../../components/Banner.astro'
---

<BaseLayout title="Extension" description=".">
    <Banner
        title="Extensión"
        description="Actualización para la Justicia de Paz Bonaerense."
        showButton={false}
    />
    <section>
        <h2 class="titulo">Curso para la Actualización de Paz Bonaerense</h2>
        <p class="font-cuerpo text-xl p-2 text-gray-700 leading-relaxed">
            Jornadas mensuales de capacitación para abogados, miembros del
            sistema judicial y estudiantes avanzados de la carrera de abogacía.
        </p>
        <p class="font-cuerpo text-xl p-2 text-gray-700 leading-relaxed">
            Modalidad: Presencial. Dos encuentros por mes durante 2025.
        </p>
        <p class="font-cuerpo text-xl p-2 text-gray-700 leading-relaxed">
            Financiamiento: Foro de la Justicia de Paz y aporte de los
            participantes.
        </p>
    </section></BaseLayout
>
