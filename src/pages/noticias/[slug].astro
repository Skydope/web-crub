---
import { getCollection } from "astro:content";
import Layout from "../../layouts/BaseLayout.astro";
import ShareButtons from "../../components/ShareButtons.astro";

const { entry } = Astro.props;
const url = Astro.url.href;

// 🚀 Generamos las rutas estáticas
export async function getStaticPaths() {
  const noticias = await getCollection("noticias");
  return noticias.map((noticia) => ({
    params: { slug: noticia.slug },
    props: { noticia },
  }));
}

const { noticia } = Astro.props;

// ✅ Import dinámico del renderer de contenido
const { Content } = await noticia.render();
---

<Layout title={noticia.data.titulo}>
  <!-- Complete magazine-style redesign with professional layout -->
  <article class="min-h-screen bg-gradient-to-b from-slate-50 to-white">
    <!-- Hero Section -->
    <div class="relative h-[60vh] min-h-[500px] overflow-hidden bg-slate-900">
      <img
        src={noticia.data.imagen || "/placeholder.svg"}
        alt={noticia.data.titulo}
        class="w-full h-full object-cover opacity-80"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/50 to-transparent"></div>
      
      <!-- Title Overlay -->
      <div class="absolute bottom-0 left-0 right-0 px-6 pb-12 md:px-12 lg:px-16">
        <div class="max-w-4xl mx-auto">
          <!-- Category Badge -->
          <span class="inline-block px-4 py-1.5 mb-4 text-sm font-semibold tracking-wider uppercase bg-blue-600 text-white rounded-sm">
            {noticia.data.categoria}
          </span>
          
          <!-- Title -->
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-4 text-balance">
            {noticia.data.titulo}
          </h1>
          
          <!-- Meta Info -->
          <div class="flex items-center gap-4 text-slate-300 text-sm md:text-base">
            <time class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {new Date(noticia.data.fecha).toLocaleDateString("es-AR", {
                day: "numeric",
                month: "long",
                year: "numeric",
              })}
            </time>
          </div>
        </div>
      </div>
    </div>

    <!-- Content Section -->
    <div class="max-w-4xl mx-auto px-6 md:px-12 lg:px-16 py-12">
      <!-- Decorative Top Line -->
      <div class="flex items-center gap-4 mb-12">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-slate-300 to-transparent"></div>
        <div class="w-2 h-2 rounded-full bg-blue-600"></div>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-slate-300 to-transparent"></div>
      </div>

      <!-- Article Content -->
      <div class="prose prose-lg prose-slate max-w-none
                  prose-headings:font-bold prose-headings:text-slate-900
                  prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h2:border-l-4 prose-h2:border-blue-600 prose-h2:pl-4
                  prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-4
                  prose-p:text-slate-700 prose-p:leading-relaxed prose-p:text-justify prose-p:mb-6
                  prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
                  prose-strong:text-slate-900 prose-strong:font-semibold
                  prose-blockquote:border-l-4 prose-blockquote:border-blue-600 prose-blockquote:bg-slate-50 prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:not-italic prose-blockquote:text-slate-700
                  prose-ul:list-disc prose-ul:pl-6
                  prose-ol:list-decimal prose-ol:pl-6
                  prose-li:text-slate-700 prose-li:mb-2
                  prose-img:rounded-lg prose-img:shadow-lg prose-img:my-8">
        <Content />
      </div>

      <!-- Decorative Bottom Line -->
      <div class="flex items-center gap-4 mt-16 mb-8">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-slate-300 to-transparent"></div>
        <div class="w-2 h-2 rounded-full bg-blue-600"></div>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-slate-300 to-transparent"></div>
      </div>

      <!-- Share Section -->
      <div class="flex items-center justify-between py-8 border-t border-slate-200">
        <p class="text-sm text-slate-600 font-medium">Compartir artículo</p>
        <div class="flex gap-3">
          <button class="w-10 h-10 rounded-full bg-slate-100 hover:bg-blue-600 hover:text-white transition-colors flex items-center justify-center text-slate-600" aria-label="Compartir en Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </button>
          <button class="w-10 h-10 rounded-full bg-slate-100 hover:bg-blue-600 hover:text-white transition-colors flex items-center justify-center text-slate-600" aria-label="Compartir en Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </button>
          <button class="w-10 h-10 rounded-full bg-slate-100 hover:bg-blue-600 hover:text-white transition-colors flex items-center justify-center text-slate-600" aria-label="Compartir en LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </button>
        </div>
      </div>


      <!-- Back to News -->
      <div class="mt-12 mb-8">
        <a href="/" class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 font-medium transition-colors group">
          <button
          class=" inline-flex  bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-900 transition-all duration-300 transform hover:scale-105 shadow-lg"
          >
          <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          <span class="ml-1">Volver a Noticias</span>
          </button>
        </a>
      </div>
    </div>
  </article>
</Layout>
