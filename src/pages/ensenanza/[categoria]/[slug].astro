---
import Layout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Banner from "../../../components/Banner.astro";
import Faq from "../../../components/Faq.astro";
import { CARPETA_A_URL, TITULOS } from "../../../utils/niveles";

export async function getStaticPaths() {
  const propuestas = await getCollection("propuestas");

  const paths = propuestas
    .filter((p) => p.data.nivel !== "pregrado")
    .map((p) => {
      const categoriaUrl = CARPETA_A_URL[p.data.nivel] ?? p.data.nivel;

      return {
        params: {
          categoria: categoriaUrl,
          slug: p.slug.split("/").pop(),
        },
        props: {
          propuesta: p,
          categoria: categoriaUrl,
        },
      };
    });

  return paths;
}

const { propuesta, categoria } = Astro.props;
const capitalize = (str: string) => str.charAt(0).toUpperCase() + str.slice(1);

const faqsCarrera = [
  {
    question: "¿Qué necesito para inscribirme?",
    answer: "Necesitas: certificado de secundario completo legalizado, fotocopia de DNI, 2 fotos 4x4, y completar el formulario de inscripción. Para estudiantes extranjeros, se requiere certificado de estudios apostillado y traducido por traductor público."
  },
  {
    question: "¿Qué salida laboral tiene?",
    answer: "Los egresados pueden desempeñarse en empresas públicas y privadas, desarrollar su práctica profesional de forma independiente, trabajar en organismos gubernamentales, centros de investigación, y emprendimientos propios del sector."
  },
  {
    question: "¿Cuál es el costo de la carrera?",
    answer: "La carrera es gratuita. Solo debes abonar el derecho a examen por materia rendida. Además, contamos con programas de becas para estudiantes que cumplan con los requisitos establecidos."
  },
  {
    question: "¿Qué modalidad de cursada ofrecen?",
    answer: "Ofrecemos modalidad presencial con clases de lunes a viernes en turno mañana y tarde. Algunas materias cuentan con opción semipresencial. La asistencia mínima requerida es del 75% para regularizar las materias."
  },
  {
    question: "¿Cuándo comienzan las inscripciones?",
    answer: "Las inscripciones para el ciclo lectivo se abren en diciembre y enero. Para el segundo cuatrimestre, hay un período especial en junio-julio. Te recomendamos estar atento a nuestras redes sociales y sitio web para las fechas exactas."
  }
];
---

<Layout title={propuesta.data.titulo} description={propuesta.data.universidad}>
  <Banner
    title={propuesta.data.titulo}
    description={propuesta.data.universidad}
    showButton={false}
    heightClass="py-20"
  />

  <section class="max-w-7xl mx-auto py-12 px-4">
    <a 
      href={`/ensenanza/${categoria}`} 
      class="inline-flex items-center gap-2 mb-8 bg-blue-900 text-white px-2 mt-1 py-1 rounded-lg font-semibold hover:bg-blue-600  transition-all duration-300 transform hover:scale-105 shadow-lg"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a {capitalize(categoria)}
    </a>

    <div class="grid lg:grid-cols-3 gap-8">
      <aside class="lg:col-span-1">
        <div class="bg-white rounded-xl shadow-lg overflow-hidden mb-6">
          <img 
            src={`/img/logos-universidades/${propuesta.data.img}.jpg`} 
            alt={propuesta.data.titulo}
            class="w-full h-56 object-cover"
          />
        </div>

        <div class="bg-white rounded-xl shadow-lg p-6 space-y-6">
          <h3 class="text-xl font-bold text-gray-900 mb-4 border-b pb-3">
            Información General
          </h3>

          <div class="space-y-2">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              Institución
            </div>
            <p class="text-gray-900 font-semibold pl-7">{propuesta.data.universidad}</p>
          </div>

          <div class="space-y-2">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Duración
            </div>
            <p class="text-gray-900 font-semibold pl-7">{propuesta.data.duracion}</p>
          </div>

          <div class="space-y-2">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Modalidad
            </div>
            <p class="text-gray-900 font-semibold pl-7">{propuesta.data.modalidad}</p>
          </div>

          <div class="space-y-2">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Financiamiento
            </div>
            <p class="text-gray-900 font-semibold pl-7">{propuesta.data.financiamiento}</p>
          </div>

          <div class="space-y-2 pt-4 border-t">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Inscripción
            </div>
            <a 
      href="/inscripciones" 
      class="inline-flex items-center gap-2 mb-8 bg-blue-900 text-white px-2 mt-1 py-1 rounded-lg font-semibold hover:bg-blue-600  transition-all duration-300 transform hover:scale-105 shadow-lg"
    >
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
</svg>
      Inscribirme
    </a>
          </div>

          <div class="space-y-2 pt-4 border-t">
            <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
              </svg>
              Categoría
            </div>
            <a href={`/ensenanza/${categoria}`}>
            <span class="inline-block ml-7 px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm font-semibold">
              {capitalize(categoria)}
            </span>
            </a>
          </div>
        </div>
      </aside>

      <main class="lg:col-span-2">
        <div class="bg-white rounded-xl shadow-lg p-8">
          <h1 class="text-3xl font-bold mb-6 text-gray-900 border-b pb-4">
            {propuesta.data.titulo}
          </h1>
          <article class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-p:text-gray-700 prose-a:text-blue-600 prose-strong:text-gray-900">
            {propuesta.body}
          </article>
  <Faq
  title="Preguntas frecuentes"
  subtitle="Resolvemos tus dudas sobre inscripción, cursada y más"
  faqs={faqsCarrera}
/>
        </div>
         <a 
      href={`/ensenanza/${categoria}`} 
      class="lg:hidden flex justify-center  gap-2 mb-8 bg-blue-900 text-white px-2 mt-4 py-1 rounded-lg font-semibold hover:bg-blue-600  transition-all duration-300 transform hover:scale-105 shadow-lg"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a {capitalize(categoria)}
    </a>
      </main>
    </div>
  </section>
</Layout>
