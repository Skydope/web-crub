---
import Layout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Banner from "../../components/Banner.astro";
import { URL_A_CARPETA, TITULOS } from "../../utils/niveles";

export async function getStaticPaths() {
  const categorias = ["carreras", "diplomaturas"];

  return categorias.map((categoria) => ({
    params: { categoria },
  }));
}

const { categoria } = Astro.params;
const propuestas = await getCollection("propuestas");

const carpeta = URL_A_CARPETA[categoria];
const propuestasFiltradas = propuestas.filter((p) => p.id.split("/")[0] === carpeta);

const tituloBanner = TITULOS[categoria] ?? "Propuestas académicas";
---

<Layout title={tituloBanner} description={`${tituloBanner} del CRUB: conoce las propuestas, universidades, duracion y modalidades disponibles en Bolivar.`}>
<Banner
  title={tituloBanner}
  description={`Explora nuestras ${tituloBanner.toLowerCase()} disponibles`}
  showButton={false}
/>

<section class="max-w-5xl mx-auto py-20 min-h-[70vh]">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {propuestasFiltradas.map((p) => (
        <a href={`/ensenanza/${categoria}/${p.slug.split("/").pop()}`}>
        <article class="p-4 bg-white rounded-lg shadow-md">
          <img 
            src={`/img/logos-universidades/${p.data.img}.jpg`} alt={p.data.universidad} 
            class="w-[293px] h-[149px] object-cover rounded"
            />
          <h2 class="text-xl font-semibold">{p.data.titulo}</h2>
          <p class="text-sm text-gray-600">{p.data.universidad}</p>
          <p class="text-sm">{p.data.duracion}</p>
          <p class="text-sm">{p.data.modalidad}</p>
          <p class="text-sm">{p.data.financiamiento}</p>
        </article>
        </a>
      ))}
    </div>
  </section>
</Layout>
