---
import BaseLayout from '../layouts/BaseLayout.astro'
import Banner from '../components/Banner.astro'
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe o ha sido movida"
>
  <Banner
    title="404 - Página no encontrada"
    description="Lo sentimos, la página que estás buscando no existe o ha sido movida."
    gradient="from-blue-900 to-blue-700"
    overlayOpacity={0.3}
    patternOpacity={0.2}
    heightClass="py-20 lg:py-28"
  >
    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="/" class="inline-block">
        <button
          class="bg-white text-blue-900 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-all duration-300 transform hover:scale-105 shadow-lg"
        >
          Volver al inicio
        </button>
      </a>
      <a href="/contacto" class="inline-block">
        <button
          class="bg-transparent border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-blue-900 transition-all duration-300 transform hover:scale-105"
        >
          Contactar
        </button>
      </a>
    </div>
  </Banner>

  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-blue-900 mb-4">
          ¿Qué puedes hacer?
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Mientras encuentras lo que buscabas, te sugerimos explorar estas secciones de nuestro sitio
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a
          href="/institucion"
          class="bg-white p-6 rounded-lg shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1"
        >
          <div class="text-blue-900 mb-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-12 w-12 mx-auto"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-blue-900 mb-2 text-center">
            Institución
          </h3>
          <p class="text-gray-600 text-center">
            Conoce más sobre el Centro Regional Universitario Bolívar
          </p>
        </a>

        <a
          href="/oferta-academica"
          class="bg-white p-6 rounded-lg shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1"
        >
          <div class="text-blue-900 mb-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-12 w-12 mx-auto"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-blue-900 mb-2 text-center">
            Oferta Académica
          </h3>
          <p class="text-gray-600 text-center">
            Descubre nuestras carreras y programas educativos
          </p>
        </a>

        <a
          href="/contacto"
          class="bg-white p-6 rounded-lg shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1"
        >
          <div class="text-blue-900 mb-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-12 w-12 mx-auto"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-blue-900 mb-2 text-center">
            Contacto
          </h3>
          <p class="text-gray-600 text-center">
            Ponte en contacto con nosotros para más información
          </p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  section {
    animation: fadeIn 0.6s ease-out;
  }
</style>
